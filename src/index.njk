---
layout: base.njk
title: mattcavender.nfo
---

{% from "macros.njk" import sectionHeader, entry, tocRow %}

{% set postslist = collections.posts | reverse %}

<div class="toc">
<pre class="toc-title">{% set t = '-- TABLE OF CONTENTS ' %}{{ t }}{{ '-' | repeat(78 - (t | length)) }}</pre>
<pre class="toc-body">{{ tocRow('00', 'ABSTRACT', 'abstract') }}
{{ tocRow('01', 'WRITING', 'writing', postslist | length) }}
{{ tocRow('02', 'CODE', 'code', sections.CODE | length) }}
{{ tocRow('03', 'PODCASTS', 'podcasts', sections.PODCASTS | length) }}
{{ tocRow('04', 'AUDIO', 'audio', sections.AUDIO | length) }}
{{ tocRow('05', 'CONTACT', 'contact') }}</pre>
</div>

<pre class="rule">{{ '-' | repeat(78) }}</pre>

{{ sectionHeader('00', 'ABSTRACT', 'abstract', '1') }}
<pre class="prose">{{ sections.ABSTRACT }}</pre>

<pre class="rule">{{ '-' | repeat(78) }}</pre>

<div class="searchbar">
  <pre class="search-prompt"><span class="accent">&gt;_ </span><span class="search-label">grep:</span></pre>
  <input class="search-input" type="text" placeholder="filter entries..." spellcheck="false" autocomplete="off">
</div>

<pre class="rule">{{ '-' | repeat(78) }}</pre>

{{ sectionHeader('01', 'WRITING', 'writing', '2') }}
<pre class="meta-line"><span class="meta-key">feed</span>: <a class="meta-link" href="/feed.xml">https://mattcavender.com/feed.xml</a>   <span class="meta-key">format</span>: <span>RSS 2.0</span></pre>
<pre class="rule">{{ '-' | repeat(78) }}</pre>
{% if postslist | length > 0 %}
  {% for post in postslist %}
    {% set e = {
      num: '01.' + (loop.index | string | padStart(2, '0')),
      title: post.data.title,
      href: post.url,
      meta: '',
      body: post.data.description,
      tags: []
    } %}
    {{ entry(e, 'WRITING', post.data.date | dateDisplay, '8ch') }}
  {% endfor %}
{% else %}
  <pre class="empty">     -- no entries --</pre>
{% endif %}
<pre class="empty is-hidden" data-section="WRITING" data-tpl-empty='     -- no entries match "{q}" --'></pre>

{{ sectionHeader('02', 'CODE', 'code', '3') }}
<pre class="meta-line"><span class="meta-key">host</span>: <span>github.com/visionsofparadise</span></pre>
<pre class="rule">{{ '-' | repeat(78) }}</pre>
{% for e in sections.CODE %}{{ entry(e, 'CODE') }}{% endfor %}
<pre class="empty is-hidden" data-section="CODE" data-tpl-empty='     -- no entries match "{q}" --'></pre>

{{ sectionHeader('03', 'PODCASTS', 'podcasts', '4') }}
<pre class="rule">{{ '-' | repeat(78) }}</pre>
{% for e in sections.PODCASTS %}{{ entry(e, 'PODCASTS') }}{% endfor %}
<pre class="empty is-hidden" data-section="PODCASTS" data-tpl-empty='     -- no entries match "{q}" --'></pre>

{{ sectionHeader('04', 'AUDIO', 'audio', '5') }}
<pre class="rule">{{ '-' | repeat(78) }}</pre>
{% for e in sections.AUDIO %}{{ entry(e, 'AUDIO') }}{% endfor %}
<pre class="empty is-hidden" data-section="AUDIO" data-tpl-empty='     -- no entries match "{q}" --'></pre>

{{ sectionHeader('05', 'CONTACT', 'contact', '6') }}
{# inner content width = 76; "   [@]  " is 8 chars, email is variable, then pad with spaces #}
{% set _emailPad = 76 - 8 - (sections.CONTACT_EMAIL | length) %}
<pre class="contact-block">+----------------------------------------------------------------------------+
|                                                                            |
|   [@]  <a href="mailto:{{ sections.CONTACT_EMAIL }}">{{ sections.CONTACT_EMAIL }}</a>{{ ' ' | repeat(_emailPad) }}|
|                                                                            |
+----------------------------------------------------------------------------+</pre>
